&uart1 {
    status = "okay";
    current-speed = <921600>;
};

/ {
    aliases {
        wake-pin = &wake_pin;
        int-pin = &int_pin;
    };

    gpio_pins {
        compatible = "gpio-keys";

        wake_pin: wake_pin {
            gpios = <&gpio0 20 GPIO_ACTIVE_HIGH>;
            label = "XM125 WAKE";
        };

        int_pin: int_pin {
            gpios = <&gpio0 21 GPIO_ACTIVE_HIGH>;
            label = "XM125 INT";
        };
    };

    /*
     * Drive WAKE pin low at boot before main() runs.
     * Prevents XM125 from waking due to floating/high signal
     * on P0.20 during nRF9151 startup (~2s before main()).
     */
    gpio_hogged: gpio_hogged {
        compatible = "gpio-leds";
        wake_hog: wake_hog {
            gpios = <&gpio0 20 GPIO_ACTIVE_HIGH>;
            label = "XM125 WAKE hog";
        };
    };
};

&gpio0 {
    ngpios = <32>;
    wake-hog {
        gpio-hog;
        gpios = <20 GPIO_ACTIVE_HIGH>;
        output-low;
        line-name = "XM125 WAKE";
    };
};
